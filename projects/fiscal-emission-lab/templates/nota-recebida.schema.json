{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mensuraengenharia.com.br/schemas/fiscal/nota-recebida.schema.json",
  "title": "Nota fiscal recebida normalizada",
  "type": "object",
  "required": [
    "schema_version",
    "document_type",
    "source",
    "access_key",
    "issuer",
    "recipient",
    "issue_date",
    "total_amount",
    "currency",
    "status",
    "artifacts",
    "risk_guardrails"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "fiscal-nota-recebida-v0" },
    "document_type": { "type": "string", "enum": ["NFe", "NFCe", "CTe", "MDFe", "NFSe", "unknown"] },
    "source": {
      "type": "object",
      "required": ["mode", "origin", "real_data"],
      "properties": {
        "mode": { "type": "string", "enum": ["fixture", "manual_import", "dfe_distribution_planned", "municipal_portal_planned"] },
        "origin": { "type": "string" },
        "real_data": { "type": "boolean" },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "access_key": { "type": ["string", "null"] },
    "number": { "type": ["string", "null"] },
    "series": { "type": ["string", "null"] },
    "model": { "type": ["string", "null"] },
    "nature": { "type": ["string", "null"] },
    "issue_date": { "type": ["string", "null"], "format": "date-time" },
    "competence": { "type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}$" },
    "issuer": { "$ref": "#/$defs/party" },
    "recipient": { "$ref": "#/$defs/party" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["line", "description", "quantity", "unit_amount", "total_amount"],
        "properties": {
          "line": { "type": "integer" },
          "description": { "type": ["string", "null"] },
          "cfop": { "type": ["string", "null"] },
          "ncm": { "type": ["string", "null"] },
          "quantity": { "type": ["number", "null"] },
          "unit_amount": { "type": ["number", "null"] },
          "total_amount": { "type": ["number", "null"] }
        },
        "additionalProperties": false
      }
    },
    "total_amount": { "type": ["number", "null"] },
    "currency": { "type": "string", "const": "BRL" },
    "status": {
      "type": "object",
      "required": ["code", "description"],
      "properties": {
        "code": { "type": ["string", "null"] },
        "description": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "classification": {
      "type": "object",
      "properties": {
        "company_slug": { "type": ["string", "null"] },
        "cost_center": { "type": ["string", "null"] },
        "project": { "type": ["string", "null"] },
        "review_status": { "type": "string", "enum": ["pending_human_review", "reviewed"] }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "object",
      "required": ["xml_path", "pdf_path", "json_path"],
      "properties": {
        "xml_path": { "type": ["string", "null"] },
        "pdf_path": { "type": ["string", "null"] },
        "json_path": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "risk_guardrails": {
      "type": "object",
      "required": ["read_only", "no_external_send", "no_fiscal_status_change", "no_payment_approval"],
      "properties": {
        "read_only": { "type": "boolean", "const": true },
        "no_external_send": { "type": "boolean", "const": true },
        "no_fiscal_status_change": { "type": "boolean", "const": true },
        "no_payment_approval": { "type": "boolean", "const": true }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "party": {
      "type": "object",
      "required": ["name", "cnpj", "municipality", "uf"],
      "properties": {
        "name": { "type": ["string", "null"] },
        "cnpj": { "type": ["string", "null"] },
        "municipality": { "type": ["string", "null"] },
        "uf": { "type": ["string", "null"] },
        "state_registration": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
