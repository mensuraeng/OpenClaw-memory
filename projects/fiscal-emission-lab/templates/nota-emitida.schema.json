{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Registro de nota fiscal emitida",
  "type": "object",
  "required": ["empresa_emissora", "tipo_nota", "numero", "data_emissao", "tomador", "valor_bruto", "arquivos"],
  "properties": {
    "empresa_emissora": { "type": "string" },
    "tipo_nota": { "type": "string", "enum": ["NFS-e", "NF-e", "NFC-e", "CT-e", "MDF-e"] },
    "numero": { "type": "string" },
    "serie": { "type": "string" },
    "chave_acesso": { "type": "string" },
    "data_emissao": { "type": "string" },
    "competencia": { "type": "string" },
    "tomador": {
      "type": "object",
      "required": ["razao_social", "cnpj_cpf"],
      "properties": {
        "razao_social": { "type": "string" },
        "cnpj_cpf": { "type": "string" }
      }
    },
    "descricao": { "type": "string" },
    "valor_bruto": { "type": "number" },
    "valor_liquido": { "type": "number" },
    "retencoes": { "type": "array" },
    "obra_ou_centro_custo": { "type": "string" },
    "contas_a_receber_id": { "type": "string" },
    "arquivos": {
      "type": "object",
      "properties": {
        "pdf": { "type": "string" },
        "xml": { "type": "string" },
        "json": { "type": "string" }
      }
    },
    "status": { "type": "string" },
    "observacoes": { "type": "string" }
  }
}
